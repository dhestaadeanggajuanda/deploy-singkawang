# ─── CKAN Backend ──────────────────────────────────────────────────────────
# DMS_INTERNAL = host FETCH CKAN (IP LAN) untuk I/O server-side: build getStaticProps
#                + runtime proxy /api/resource. Tanpa butuh DNS/SSL publik.
# DMS_PUBLIC   = host PUBLIK untuk URL unduh/gambar (browser) + allowlist proxy.
DMS_INTERNAL=http://172.16.20.229:5000
DMS_PUBLIC=https://data.singkawangkota.go.id

# ─── SSL Certificate (path di host) ────────────────────────────────────────
SSL_CERT_PATH=/etc/ssl/certs/singkawangkota.go.id.crt
SSL_KEY_PATH=/etc/ssl/private/singkawangkota.go.id.key
